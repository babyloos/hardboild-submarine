{
  "name": "hardboild-submarine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node-dev --respawn --transpile-only server/index.ts",
    "dev:client": "concurrently \"esbuild client/src/main.ts --bundle --outfile=client/dist/main.js --watch\" \"esbuild client/src/game.ts --bundle --outfile=client/dist/game.js --watch\"",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "esbuild client/src/main.ts --bundle --minify --outfile=client/dist/main.js && esbuild client/src/game.ts --bundle --minify --outfile=client/dist/game.js && esbuild client/src/shop.ts --bundle --minify --outfile=client/dist/shop.js",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.20.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
